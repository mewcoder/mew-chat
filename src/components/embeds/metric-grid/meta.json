{
  "id": "metric-grid",
  "order": 2,
  "title": "指标栅格",
  "summary": "适用于：中后台驾驶舱、仪表盘一排多个核心指标（如待办、超时工单、今日成交额）。每项结构与单卡 kpi 相同，前端以栅格并排展示。",
  "schema": {
    "type": "object",
    "required": ["items"],
    "additionalProperties": false,
    "properties": {
      "items": {
        "type": "array",
        "minItems": 1,
        "maxItems": 6,
        "description": "指标项，建议 2～4 个以便并排阅读",
        "items": {
          "type": "object",
          "required": ["title", "value"],
          "additionalProperties": false,
          "properties": {
            "title": { "type": "string", "description": "指标名称" },
            "value": { "type": ["string", "number"], "description": "当前值" },
            "hint": { "type": "string", "description": "可选副说明，如环比" },
            "trend": {
              "type": "string",
              "enum": ["up", "down", "neutral"],
              "description": "涨跌；neutral 或不写不显示箭头"
            }
          }
        }
      }
    }
  },
  "example": {
    "items": [
      { "title": "待审批", "value": 14, "hint": "超 24h 3 条", "trend": "up" },
      { "title": "今日工单", "value": 1280, "hint": "完成率 94%", "trend": "neutral" },
      { "title": "异常单", "value": 6, "hint": "较昨日 -2", "trend": "down" }
    ]
  },
  "routingHint": "用户要「一排指标」「多个 KPI」「仪表盘顶栏数字」「驾驶舱概要」→ 用 metric-grid 的 items 数组；仅单个数字仍可用 kpi。"
}
