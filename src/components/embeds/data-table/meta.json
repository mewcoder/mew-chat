{
  "id": "data-table",
  "order": 3,
  "title": "数据表",
  "summary": "适用于：工单/订单/用户等列表、导出预览、多行多列对比；纯键值详情用 description-list。",
  "schema": {
    "type": "object",
    "required": ["columns", "rows"],
    "additionalProperties": false,
    "properties": {
      "columns": {
        "type": "array",
        "minItems": 1,
        "description": "表头列定义，至少一列",
        "items": {
          "type": "object",
          "required": ["key", "label"],
          "additionalProperties": false,
          "properties": {
            "key": {
              "type": "string",
              "description": "与 rows 中对象字段名对应"
            },
            "label": {
              "type": "string",
              "description": "列标题"
            }
          }
        }
      },
      "rows": {
        "type": "array",
        "description": "数据行，每项为对象，键与 columns[].key 对应",
        "items": {
          "type": "object",
          "additionalProperties": true
        }
      }
    }
  },
  "example": {
    "columns": [
      { "key": "name", "label": "任务" },
      { "key": "status", "label": "状态" }
    ],
    "rows": [
      { "name": "同步库存", "status": "进行中" },
      { "name": "对账", "status": "已完成" }
    ]
  },
  "routingHint": "多行结构化列表、报表、运维明细 → data-table；两列字段只读 → description-list。"
}
