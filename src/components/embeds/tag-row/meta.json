{
  "id": "tag-row",
  "order": 5,
  "title": "状态标签行",
  "summary": "适用于：单据状态、风险等级、流程节点等短标签横排展示，常与描述列表或表格结论一起出现。",
  "schema": {
    "type": "object",
    "required": ["items"],
    "additionalProperties": false,
    "properties": {
      "label": {
        "type": "string",
        "description": "可选：左侧说明，如「当前状态」"
      },
      "items": {
        "type": "array",
        "minItems": 1,
        "description": "标签文案 + 语义色",
        "items": {
          "type": "object",
          "required": ["text"],
          "additionalProperties": false,
          "properties": {
            "text": { "type": "string", "description": "标签文案" },
            "tone": {
              "type": "string",
              "enum": ["default", "success", "warning", "danger", "info"],
              "default": "default",
              "description": "语义色：成功/警示/危险/信息/默认灰"
            }
          }
        }
      }
    }
  },
  "example": {
    "label": "标记",
    "items": [
      { "text": "待审批", "tone": "warning" },
      { "text": "加急", "tone": "danger" },
      { "text": "华东区", "tone": "info" }
    ]
  },
  "routingHint": "用户要「状态徽标」「彩色标签」「风险等级条」→ 用 tag-row；纯文字列举无颜色语义时用 Markdown 列表即可。"
}
