{
  "id": "chart-pie",
  "order": 10,
  "title": "饼图",
  "summary": "适用于：部门业绩占比、费用结构、渠道构成等；仅需 `items`（`name` + `value`），无需 ECharts option。",
  "schema": {
    "type": "object",
    "required": ["items"],
    "additionalProperties": false,
    "properties": {
      "title": {
        "type": "string",
        "description": "可选：图表上方说明标题"
      },
      "height": {
        "type": "number",
        "minimum": 120,
        "maximum": 900,
        "description": "图表区域高度（像素），默认 320"
      },
      "donut": {
        "type": "boolean",
        "description": "是否使用环形图，默认 false（实心饼）"
      },
      "items": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "object",
          "required": ["name", "value"],
          "additionalProperties": false,
          "properties": {
            "name": { "type": "string", "description": "分类名称" },
            "value": { "type": "number", "description": "数值（占比按 value 相对大小计算）" }
          }
        }
      }
    }
  },
  "example": {
    "title": "访问来源",
    "height": 300,
    "donut": true,
    "items": [
      { "name": "直接访问", "value": 335 },
      { "name": "搜索引擎", "value": 234 },
      { "name": "外链", "value": 154 }
    ]
  },
  "routingHint": "占比、构成、结构分布 → chart-pie（可 donut: true 环形）；趋势用 chart-line。"
}
