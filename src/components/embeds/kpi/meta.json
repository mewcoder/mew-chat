{
  "id": "kpi",
  "order": 1,
  "title": "指标卡（单指标）",
  "summary": "适用于：中后台单指标强调展示，如「待我审批」数量、部门今日工单、同比等；同一回答里多个并列数字请优先 metric-grid。",
  "schema": {
    "type": "object",
    "required": ["title", "value"],
    "additionalProperties": false,
    "properties": {
      "title": {
        "type": "string",
        "description": "指标名称"
      },
      "value": {
        "type": ["string", "number"],
        "description": "当前值"
      },
      "hint": {
        "type": "string",
        "description": "可选副说明，如环比文案"
      },
      "trend": {
        "type": "string",
        "enum": ["up", "down", "neutral"],
        "description": "涨跌提示；neutral 或不写则不显示箭头"
      }
    }
  },
  "example": {
    "title": "今日订单",
    "value": 1280,
    "hint": "较昨日 +12%",
    "trend": "up"
  },
  "routingHint": "只展示一个核心数且需要卡片强调（如「待审批 14 单」）→ kpi；多个并排数字 → metric-grid。"
}
