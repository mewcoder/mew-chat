{
  "id": "description-list",
  "order": 4,
  "title": "描述列表",
  "summary": "适用于：订单详情、用户信息、配置只读预览等「标签 + 值」只读字段列表。多行两列栅格，避免长表格。",
  "schema": {
    "type": "object",
    "required": ["items"],
    "additionalProperties": false,
    "properties": {
      "title": {
        "type": "string",
        "description": "可选：整块区域标题，如「基本信息」"
      },
      "items": {
        "type": "array",
        "minItems": 1,
        "description": "字段列表，每项为标签与展示值",
        "items": {
          "type": "object",
          "required": ["label", "value"],
          "additionalProperties": false,
          "properties": {
            "label": { "type": "string", "description": "字段名" },
            "value": {
              "type": ["string", "number", "boolean"],
              "description": "展示值；复杂结构请先格式化为字符串"
            }
          }
        }
      }
    }
  },
  "example": {
    "title": "订单概要",
    "items": [
      { "label": "订单号", "value": "SO-20260325-001" },
      { "label": "客户", "value": "某科技有限公司" },
      { "label": "金额（元）", "value": 12800 },
      { "label": "状态", "value": "待发货" }
    ]
  },
  "routingHint": "用户要「详情字段」「只读信息」「标签值对」「表单预览」→ 用 description-list，不要用 data-table 撑两列。"
}
