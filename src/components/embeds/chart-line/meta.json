{
  "id": "chart-line",
  "order": 12,
  "title": "折线图",
  "summary": "适用于：DAU/交易量趋势、SLA 达标率变化、按时间或阶段的变化曲线。`items` 顺序即横轴；可选 `smooth`、`area` 强调趋势。",
  "schema": {
    "type": "object",
    "required": ["items"],
    "additionalProperties": false,
    "properties": {
      "title": {
        "type": "string",
        "description": "可选：图表上方说明标题"
      },
      "height": {
        "type": "number",
        "minimum": 120,
        "maximum": 900,
        "description": "图表区域高度（像素），默认 320"
      },
      "unit": {
        "type": "string",
        "description": "可选：纵轴名称，如「人次」「℃」"
      },
      "smooth": {
        "type": "boolean",
        "default": true,
        "description": "是否平滑曲线，默认 true"
      },
      "area": {
        "type": "boolean",
        "description": "是否显示面积填充（浅色），默认 false"
      },
      "items": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "object",
          "required": ["name", "value"],
          "additionalProperties": false,
          "properties": {
            "name": { "type": "string", "description": "横轴标签（如日期、阶段）" },
            "value": { "type": "number", "description": "该点的数值" }
          }
        }
      }
    }
  },
  "example": {
    "title": "近五日访问趋势",
    "height": 280,
    "unit": "次",
    "smooth": true,
    "area": true,
    "items": [
      { "name": "周一", "value": 120 },
      { "name": "周二", "value": 182 },
      { "name": "周三", "value": 151 },
      { "name": "周四", "value": 234 },
      { "name": "周五", "value": 290 }
    ]
  },
  "routingHint": "时序、趋势线、阶段变化 → chart-line；静态分类对比 → chart-bar。"
}
